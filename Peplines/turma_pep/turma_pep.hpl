  <transform>
    <type>TableInput</type>
    <name>Table input</name>
    <sql>SELECT 
    t.cod_disc,
    t.numero AS numero_turma,
    t.ano,
    t.semestre,
	count(c.mat_estudante) as total_alunos,
    ROUND(AVG(c.nota)::numeric, 2) AS media_notas,
    SUM(CASE WHEN c.nota >= 5 THEN 1 ELSE 0 END) AS qtd_aprovados,
    SUM(CASE WHEN c.nota &lt; 5 THEN 1 ELSE 0 END) AS qtd_reprovados
FROM universidade.cursa c
INNER JOIN universidade.turma t ON c.id_turma = t.id_turma
GROUP BY t.cod_disc, t.numero, t.ano, t.semestre;</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>univeridade</connection>
    <lookup/>
    <sql_from_file/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
